# ==============================================================================
# OpenBioFlow AI - Environment Configurations
# ==============================================================================

# 1. Primary PostgreSQL Settings
DB_USER=postgres
DB_PASSWORD=postgres_dev_pwd
DB_NAME=openbioflow_dev
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres_dev_pwd@localhost:5432/openbioflow_dev

# 2. Redis Caching Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# 3. Object Storage (S3 / MinIO) Settings
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=openbioflow-data
S3_ENDPOINT=http://localhost:9000
S3_USE_SSL=false

# 4. Google Gemini API Credentials
# Retrieve your key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 5. Application Gateway Settings
GATEWAY_PORT=8000
SECRET_KEY=super_secure_random_key_for_jwts
ACCESS_TOKEN_EXPIRE_MINUTES=60
